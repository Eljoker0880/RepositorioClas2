    public static MembresiaService membresiaService = new MembresiaService();

    // FIX: AnsiConsole.Clear() (el de Spectre.Console) en algunas consolas solo
    // limpia la parte visible sin resetear bien el buffer/cursor, provocando que
    // el contenido se vaya "corriendo" hacia abajo en cada redibujado y el logo
    // quede fuera de vista. Console.Clear() (nativo de .NET) sí resetea el buffer
    // por completo. Si la salida está redirigida (no soporta Console.Clear()),
    // se usa AnsiConsole.Clear() como respaldo.
    public static void LimpiarConsola()
    {
        try
        {
            Console.Clear();
        }
        catch (IOException)
        {
            AnsiConsole.Clear();
        }
    }

    // ---------- TABLA DETALLADA DE MIEMBROS (compartida entre el menú principal y "Mostrar miembros") ----------
    // FIX: antes existían dos tablas distintas: una simplificada (CrearTablaMenu)
    // para el panel del menú principal, y otra detallada dentro de MostrarMiembros().
    // Ahora ambas usan esta misma tabla, así siempre se ve la misma información.
    // FIX: se agregó un parámetro opcional "limite" para poder mostrar solo una
    // vista previa (pocas filas) en el panel del menú principal, y así evitar
    // que el panel crezca demasiado a lo alto cuando hay muchos miembros
    // registrados. La opción "1. Mostrar miembros" sigue mostrando la lista
    // completa, llamando a este mismo método sin límite.
    public static Table CrearTablaDetallada(int? limite = null)
    {
        var table = new Table();
        table.Border(TableBorder.Rounded);

        // FIX: se fija un ancho por columna y se usa NoWrap(), para que el
        // texto de cada celda no se parta letra por letra en varias líneas
        // (lo que pasaba al agregar miembros con nombres/teléfonos más largos
        // o al angostar/ensanchar el panel). NoWrap fuerza una sola línea por
        // celda; si el contenido no cabe, Spectre lo recorta automáticamente.
        table.AddColumn(new TableColumn("Id").Width(18).NoWrap());
        table.AddColumn(new TableColumn("Nombre").Width(20).NoWrap());
        table.AddColumn(new TableColumn("Apellido").Width(20).NoWrap());
        table.AddColumn(new TableColumn("Teléfono").Width(24).NoWrap());
        table.AddColumn(new TableColumn("Tipo").Width(22).NoWrap());
        table.AddColumn(new TableColumn("Inicio").Width(25).NoWrap());
        table.AddColumn(new TableColumn("Vencimiento").Width(25).NoWrap());
        table.AddColumn(new TableColumn("Estado").Width(22).NoWrap());

        List<Miembro> miembros = miembroService.FindAll();

        if (limite.HasValue)
            miembros = miembros.Take(limite.Value).ToList();

        foreach (Miembro miembro in miembros)
        {
            Membresia? membresia = membresiaService.FindByMiembroId(miembro.id);

            string estado = "[grey]Sin membresía[/]";

            // FIX: "Vencimiento" ahora muestra la fecha (igual formato que "Inicio"),
            // ya no el conteo regresivo hh:mm:ss. El conteo regresivo solo se usa
            // internamente para calcular el color/estado, no para mostrarse.
            string vencimiento = membresia?.Vencimiento.ToString("dd/MM/yyyy") ?? "-";

            if (membresia != null)
            {
                TimeSpan tiempoRestante = membresia.Vencimiento - DateTime.Now;

                if (tiempoRestante.TotalSeconds < 0)
                {
                    estado = "[red]🔴 Vencida[/]";
                }
                else
                {
                    double alertaSegundos = 15 * 24 * 60 * 60; // 15 días

                    if (membresia.Tipo == "30 Segundos")
                        alertaSegundos = 10;
                    else if (membresia.Tipo == "1 Día")
                        alertaSegundos = 24 * 60 * 60;
                    else if (membresia.Tipo == "1 Semana")
                        alertaSegundos = 3 * 24 * 60 * 60;

                    estado = tiempoRestante.TotalSeconds <= alertaSegundos
                        ? "[yellow]🟡 Próxima a vencer[/]"
                        : "[green]🟢 Activo[/]";
                }
            }

            table.AddRow(
                miembro.id.ToString(),
                miembro.Nombre,
                miembro.Apellido,
                miembro.Telefono,
                membresia?.Tipo ?? "-",
                membresia?.Inscripcion.ToString("dd/MM/yyyy") ?? "-",
                vencimiento,
                estado
            );
        }

        return table;
    }

